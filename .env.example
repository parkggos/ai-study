# Vercel Dashboard → Project → Settings → Environment Variables
# ERP 분석보고서(api/erp-report.js) · AI News Reporter(api/news-report.js) 공통
GEMINI_API_KEY=AQ.xxxx
GEMINI_MODEL=gemini-2.5-flash

# Supabase — 로또 추첨 기록 저장 (Project URL만, /rest/v1/ 제외)
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# OpenAI 사용 시 (선택)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# AI News Reporter — 이메일 발송 (Resend)
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxx
# 인증된 도메인 이메일 (미설정 시 onboarding@resend.dev 사용)
RESEND_FROM_EMAIL=AI News Reporter <onboarding@resend.dev>
